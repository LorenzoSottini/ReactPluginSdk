{
  "name": "plugin-cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "bin": {
    "acme-plugin": "./bin/acme-plugin.mjs"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "files": [
    "src",
    "bin"
  ],
  "scripts": {
    "start": "jiti ./src/index.ts",
    "check:ts": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@acme/plugin-contracts": "workspace:*",
    "@clack/prompts": "^1.0.1",
    "cac": "^7.0.0",
    "jiti": "^1.17.0",
    "picocolors": "^1.0.0",
    "plugin-templates": "workspace:*",
    "uuid": "13.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "typescript": "catalog:"
  }
}
